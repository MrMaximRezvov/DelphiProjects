program Project1;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils;

type
  tstudents = record
    fname, name: string[50];
    weight, age: uint8;
  end;

  tar = array [0 .. 10] of tstudents;

var
  rec: tstudents;
  students: tar;
  i: int32;

begin
  for i := 1 to 10 do
  begin
    writeln('Введите данные ученика ', i, '/10:');
    writeln('Фамилия:');
    readln(rec.fname);
    writeln('Имя:');
    readln(rec.name);
    writeln('Вес:');
    readln(rec.weight);
    writeln('Возвраст:');
    readln(rec.age);
    students[i] := rec;
  end;

  for i := 1 to 10 do
  begin
    writeln('Данные ученика ', i, '/10');
    rec := students[i];
    writeln('Фамилия:', rec.fname);
    writeln('Имя:', rec.name);
    writeln('Вес:', rec.weight	);
    writeln('Возвраст:', rec.age	);
  end;
readln;
end.
