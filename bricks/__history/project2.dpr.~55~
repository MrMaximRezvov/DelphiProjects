uses System.Sysutils;

const
  k1 = 2; // Вес 2
  k2 = 4; // Вес 4
var
  L, L1, L2: int32;
  h: uint32;

//
function cnt(n: uint16): uint32;
var
  i: uint16;
  ar: array [1..4] of uint32;
begin
  // Инициализация массива для длин 1, 2, 3, 4
  ar[1] := 0; // Для длины 1 нет решений
  ar[2] := 1; // Для длины 2 одно решение: [2]
  ar[3] := 0; // Для длины 3 нет решений
  ar[4] := 2; // Для длины 4 два решения: [2, 2] и [4]

  if n <= 4 then
  begin
    if n = 0 then
      result := 0
    else
      result := ar[n];
    exit;
  end;

  // Динамическое программирование для n > 4
  for i := 5 to n do
  begin
    result := ar[1] + ar[3]; // Используем веса 2 и 4
    ar[1] := ar[2];
    ar[2] := ar[3];
    ar[3] := ar[4];
    ar[4] := result;
  end;
end;

//
begin
  repeat
    try
      write('Введите L >= 0 : ');
      readln(L);
      if L < 0 then
        continue;

      case L of
        0..1:
          h := 0; // Для длин 0 и 1 нет решений
        2:
          h := 1; // Для длины 2 одно решение: [2]
        3:
          h := 0; // Для длины 3 нет решений
        4:
          h := 2; // Для длины 4 два решения: [2, 2] и [4]
      else
        begin
          if odd(L) then
            L1 := 0//(L - k1) div 2 // Для нечётных L
          else
          begin
            L1 := L div 2; // Для чётных L
            L2 := (L - k2) div 2; // Учитываем возможность использования веса 4
          end;
          h := cnt(L1) + cnt(L2); // Суммируем результаты
        end;
      end;
      writeln('Количество рядов = ', h);
    except
      on E: Exception do
        writeln(E.ClassName);
    end;
  until false;
end.
