function gmethod(const A: Tmatr_arr; out ko: integer): Tmatr_arr;
var
  n, i, i1, j, j1: integer;
  k, factor: real;
  T: Tmatr_arr;
  Ainv: Tmatr_arr;
begin
  n := length(A);
  if (n = 0) or (n <> length(A[0])) then
    raise Exception.Create('Matrix A must be square and non-empty');

  ko := 0;

  setlength(T, n, 2 * n);
  for i := 0 to n - 1 do
  begin
    for j := 0 to n - 1 do
      T[i, j] := A[i, j];
    for j := 0 to n - 1 do
      T[i, n + j] := Ord(i = j);
  end;

  for i := 0 to n - 2 do
  begin
    if Abs(T[i, i]) < 1E-10 then
      raise Exception.Create('Leading element is zero at row ' +
        IntToStr(i + 1));

    for i1 := i + 1 to n - 1 do
    begin
      if Abs(T[i1, i]) < 1E-10 then
        continue;

      k := T[i1, i] / T[i, i];
      T[i1, i] := 0.0;
      inc(ko);

      for j := i + 1 to n + i - 1 do
      begin
        T[i1, j] := T[i1, j] - k * T[i, j];
      end;
      inc(ko, n - 1);

      T[i1, n + i] := T[i1, n + i] - k;
    end;
  end;

  for j := 1 to n - 1 do
  begin
    for i := j - 1 downto 0 do
    begin
      if Abs(T[i, j]) < 1E-10 then
        continue;

      k := T[i, j] / T[j, j];
      T[i, j] := 0.0;
      inc(ko);

      for j1 := j + 1 to n + j - 1 do
      begin
        T[i, j1] := T[i, j1] - k * T[j, j1];
      end;
      inc(ko, n - 1);

      T[i, n + j] := T[i, n + j] - k;
    end;
  end;

  for i := 0 to n - 1 do
  begin
    factor := T[i, i];
    for j := n to 2 * n - 1 do
    begin
      T[i, j] := T[i, j] / factor;
    end;
    inc(ko, n);
  end;

  setlength(Ainv, n, n);
  for i := 0 to n - 1 do
    for j := 0 to n - 1 do
      Ainv[i, j] := T[i, n + j];

  result := Ainv;
end;

procedure scalar_product(v1, v2: Tmatr_arr; out square: real; out len: real);
var
  i, n: integer;
  dot_product: real;
begin
  n := length(v1);
  if (n <> length(v2)) or (n = 0) then
    raise Exception.Create
      ('Vectors must have the same length and be non-empty');

  if (length(v1[0]) <> 1) or (length(v2[0]) <> 1) then
    raise Exception.Create('Inputs must be column vectors (n x 1)');

  dot_product := 0.0;
  for i := 0 to n - 1 do
  begin
    dot_product := dot_product + v1[i, 0] * v2[i, 0];
  end;

  square := dot_product * dot_product;
  len := Abs(dot_product);
end;

// Функция scalar_product_via_matrix: вычисляет скалярное произведение через C^T * C.
// a, b: векторы (Tmatr_arr размером n x 1)
// out square: выходной параметр - квадрат скалярного произведения (a·b)^2
// out len: выходной параметр - длина (норма) скалярного произведения |a·b|
procedure scalar_product_via_matrix(a, b: Tmatr_arr; out square: real; out len: real);
var
  n, i, j, k: integer;
  C: Tmatr_arr; // Матрица n x 2: столбцы — векторы a и b
  CT_C: Tmatr_arr; // Результат C^T * C (размер 2x2)
begin
  n := length(a);
  if (n <> length(b)) or (n = 0) then
    raise Exception.Create('Vectors must have the same length and be non-empty');

  if (length(a[0]) <> 1) or (length(b[0]) <> 1) then
    raise Exception.Create('Inputs must be column vectors (n x 1)');

  // Шаг 1: Собираем матрицу C = [a | b] (размер n x 2)
  setlength(C, n, 2);
  for i := 0 to n - 1 do
  begin
    C[i, 0] := a[i, 0]; // Первый столбец — вектор a
    C[i, 1] := b[i, 0]; // Второй столбец — вектор b
  end;

  // Шаг 2: Вычисляем C^T * C (размер 2x2)
  setlength(CT_C, 2, 2);

  for i := 0 to 1 do
    for j := 0 to 1 do
    begin
      CT_C[i, j] := 0.0;
      for k := 0 to n - 1 do
        CT_C[i, j] := CT_C[i, j] + C[k, i] * C[k, j];
    end;

  // Шаг 3: Извлекаем скалярное произведение из CT_C
  // CT_C[0, 1] = a·b, CT_C[1, 0] = b·a = a·b
  var dot_product := CT_C[0, 1];

  square := dot_product * dot_product; // (a·b)^2
  len := Abs(dot_product);            // |a·b|

end;

end.
