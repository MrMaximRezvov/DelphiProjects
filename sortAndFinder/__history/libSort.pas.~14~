unit libSort;

interface

uses
  System.SysUtils,
  service;

procedure BubbleSort(var Arr: TIntArray); overload;
procedure BubbleSort(var Arr: TRealArray); overload;

implementation

procedure BubbleSort(var Arr: TIntArray); overload;

var
  i, j, temp: Integer;
  n: Integer;
  T1, T2, Freq: Int64;
begin
  QueryPerformanceFrequency(Freq); // Получаем частоту таймера
  QueryPerformanceCounter(T1);    // Засекаем начало
  n := Length(Arr);
  for i := 0 to n - 2 do
    for j := 0 to n - 2 - i do
      if Arr[j] > Arr[j + 1] then
      begin
        temp := Arr[j];
        Arr[j] := Arr[j + 1];
        Arr[j + 1] := temp;
      end;
        QueryPerformanceCounter(T2);    // Засекаем конец
  Writeln(Format('Время сортировки (Int): %.6f сек', [(T2 - T1) / Freq]));
end;

procedure BubbleSort(var Arr: TRealArray); overload;

var
  i, j: Integer;
  temp: real;
  n: Integer;
begin
  n := Length(Arr);
  for i := 0 to n - 2 do
    for j := 0 to n - 2 - i do
      if Arr[j] > Arr[j + 1] then
      begin
        temp := Arr[j];
        Arr[j] := Arr[j + 1];
        Arr[j + 1] := temp;
      end;
end;

end.
