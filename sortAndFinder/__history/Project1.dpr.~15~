program Project1;

{$APPTYPE CONSOLE}

uses
  System.SysUtils,
  Unit1 in 'Unit1.pas',
  service in 'service.pas';



procedure BubbleSort(var Arr: TIntArray);
var
  i, j, temp: Integer;
  n: Integer;
begin
  n := Length(Arr);
  for i := 0 to n - 2 do
    for j := 0 to n - 2 - i do
      if Arr[j] > Arr[j + 1] then
      begin
        temp := Arr[j];
        Arr[j] := Arr[j + 1];
        Arr[j + 1] := temp;
      end;
end;



var
  MyArray: TIntArray;
  n: Integer;

begin
  try
    write('n = ');
    readln(n);
    GenerateArray(MyArray, n);

    PrintArray(MyArray, 'Исходный массив:');

    BubbleSort(MyArray);

    PrintArray(MyArray, 'Отсортированный массив:');

    WriteLn('Нажмите Enter для выхода...');
    readln;
  except
    on E: Exception do
      WriteLn('Ошибка: ', E.Message);
  end;

end.
