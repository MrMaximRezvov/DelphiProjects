unit service;

interface

uses
  System.SysUtils,
  Windows;

type
  TIntArray = array of Integer;
  TRealArray = array of Real;
  TCharArray = array of AnsiChar;

// --- Глобальные переменные ---
var
  G_N: uint32 = 1000;
  G_L: int32 = 0;
  G_R: int32 = 100;
  G_Seed: uint8 = 11;

// --- Генерация массивов ---
procedure GenerateArray(var Arr: TIntArray; Size, MinVal, MaxVal, Seed: Integer); overload;
procedure GenerateArray(var Arr: TRealArray; Size, MinVal, MaxVal, Seed: Integer); overload;
procedure GenerateArray(var Arr: TCharArray; Size, Seed: Integer); overload;

// --- Вывод массивов (ПЕРГРУЗКА!) ---
procedure PrintArray(const Arr: TIntArray; Count: Integer); overload;
procedure PrintArray(const Arr: TRealArray; Count: Integer); overload;
procedure PrintArray(const Arr: TCharArray; Count: Integer); overload;
procedure PrintLast(const Arr: TIntArray; Count: Integer); overload;
procedure PrintLast(const Arr: TRealArray; Count: Integer); overload;
procedure PrintLast(const Arr: TCharArray; Count: Integer); overload;

implementation

// --- Генерация массивов ---

procedure GenerateArray(var Arr: TIntArray; Size, MinVal, MaxVal, Seed: Integer);
var i: Integer; begin
  SetLength(Arr, Size); RandSeed := Seed;
  for i := 0 to Size - 1 do Arr[i] := Random(MaxVal - MinVal + 1) + MinVal;
end;

procedure GenerateArray(var Arr: TRealArray; Size, MinVal, MaxVal, Seed: Integer);
var i: Integer; begin
  SetLength(Arr, Size); RandSeed := Seed;
  for i := 0 to Size - 1 do Arr[i] := Random * (MaxVal - MinVal) + MinVal;
end;

procedure GenerateArray(var Arr: TCharArray; Size, Seed: Integer);
var i: Integer; begin
  SetLength(Arr, Size); RandSeed := Seed;
  for i := 0 to Size - 1 do Arr[i] := AnsiChar(Random(ord('z') - ord('a') + 1) + ord('a'));
end;

// --- Вывод целых чисел (11 в строке) ---

procedure PrintArray(const Arr: TIntArray; Count: Integer);
var
  i, j: Integer;
begin
  if Count > Length(Arr) then Count := Length(Arr);
  j := 0;
  for i := 0 to Count - 1 do
  begin
    Write(Arr[i]:4);
    Inc(j);
    if j mod 10 = 0 then Writeln;
  end;
  if j mod 10 <> 0 then Writeln;
end;

// --- Вывод вещественных чисел (8 знаков, 2 после запятой) ---

procedure PrintArray(const Arr: TRealArray; Count: Integer);
var
  i, j: Integer;
begin
  if Count > Length(Arr) then Count := Length(Arr);
  j := 0;
  for i := 0 to Count - 1 do
  begin
    Write(Arr[i]:8:2, ' ');
    Inc(j);
    if j mod 10 = 0 then Writeln;
  end;
  if j mod 10 <> 0 then Writeln;
end;

// --- Вывод символов ---

procedure PrintArray(const Arr: TCharArray; Count: Integer);
var
  i, j: Integer;
begin
  if Count > Length(Arr) then Count := Length(Arr);
  j := 0;
  for i := 0 to Count - 1 do
  begin
    Write(Arr[i]);
    Inc(j);
    if j mod 50 = 0 then Writeln;
  end;
  if j mod 50 <> 0 then Writeln;
end;

// --- Вывод последних N элементов ---

procedure PrintLast(const Arr: TIntArray; Count: Integer);
var
  i, StartIdx: Integer;
begin
  StartIdx := Length(Arr) - Count;
  if StartIdx < 0 then StartIdx := 0;
  for i := StartIdx to Length(Arr) - 1 do
  begin
    Write(Arr[i]:4);
    if (i - StartIdx + 1) mod 10 = 0 then Writeln;
  end;
  if (Length(Arr) - StartIdx) mod 10 <> 0 then Writeln;
end;

procedure PrintLast(const Arr: TRealArray; Count: Integer);
var
  i, StartIdx: Integer;
begin
  StartIdx := Length(Arr) - Count;
  if StartIdx < 0 then StartIdx := 0;
  for i := StartIdx to Length(Arr) - 1 do
  begin
    Write(Arr[i]:8:2, ' ');
    if (i - StartIdx + 1) mod 10 = 0 then Writeln;
  end;
  if (Length(Arr) - StartIdx) mod 10 <> 0 then Writeln;
end;

procedure PrintLast(const Arr: TCharArray; Count: Integer);
var
  i, StartIdx: Integer;
begin
  StartIdx := Length(Arr) - Count;
  if StartIdx < 0 then StartIdx := 0;
  for i := StartIdx to Length(Arr) - 1 do
    Write(Arr[i]);
  Writeln;
end;

end.
