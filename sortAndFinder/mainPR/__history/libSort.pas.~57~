end;

// ======================================
// INSERTION SORT
// ======================================

procedure InsertionSort(var Arr: TIntArray);
var
  i, j, Key, n: Integer;
begin
  n := Length(Arr);
  for i := 1 to n - 1 do
  begin
    Key := Arr[i];
    j := i - 1;
    while (j >= 0) and (Arr[j] > Key) do
    begin
      Arr[j + 1] := Arr[j];
      j := j - 1;
    end;
    Arr[j + 1] := Key;
  end;
end;

