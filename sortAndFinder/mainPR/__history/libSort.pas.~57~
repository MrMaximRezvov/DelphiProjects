// ======================================
// GNOME SORT (Ручной обмен, без Swap)
// ======================================

procedure GnomeSort(var Arr: TIntArray);
var
  i, temp: Integer;
begin
  i := 0;
  while i < High(Arr) do
  begin
    if (i = 0) or (Arr[i - 1] <= Arr[i]) then
      Inc(i)
    else
    begin
      temp := Arr[i]; // Ручная перестановка
      Arr[i] := Arr[i - 1]; // вместо Swap(Arr[i], Arr[i-1]);
      Arr[i - 1] := temp;
      Dec(i);
    end;
  end;
end;

procedure GnomeSort(var Arr: TRealArray);
var
  i: Integer;
  temp: Real;
begin
  i := 0;
  while i < High(Arr) do
  begin
    if (i = 0) or (Arr[i - 1] <= Arr[i]) then
      Inc(i)
    else
    begin
      temp := Arr[i];
      Arr[i] := Arr[i - 1];
      Arr[i - 1] := temp;
      Dec(i);
    end;
  end;
end;

procedure GnomeSort(var Arr: TCharArray);
var
  i: Integer;
  temp: AnsiChar;
begin
  i := 0;
  while i < High(Arr) do
  begin
    if (i = 0) or (Arr[i - 1] <= Arr[i]) then
      Inc(i)
    else
    begin
      temp := Arr[i];
      Arr[i] := Arr[i - 1];
      Arr[i - 1] := temp;
      Dec(i);
    end;
  end;
end;

// ======================================
// BINARY SEARCH
// ======================================

function BinSearchInt(const Arr: TIntArray; Left, Right, Key: Integer): Integer;
var
  Mid: Integer;
begin
  while Left <= Right do
  begin
    Mid := Left + ((Right - Left) div 2);
    if Arr[Mid] < Key then
      Left := Mid + 1
    else
      Right := Mid - 1;
  end;
  Result := Left;
end;

function BinSearchReal(const Arr: TRealArray; Left, Right: Integer;
  Key: Real): Integer;
var
  Mid: Integer;
begin
  while Left <= Right do
  begin
    Mid := Left + ((Right - Left) div 2);
    if Arr[Mid] < Key then
      Left := Mid + 1
    else
      Right := Mid - 1;
  end;
  Result := Left;
end;

function BinSearchChar(const Arr: TCharArray; Left, Right: Integer;
  Key: AnsiChar): Integer;
var
  Mid: Integer;
begin
  while Left <= Right do
  begin
    Mid := Left + ((Right - Left) div 2);
    if Arr[Mid] < Key then
      Left := Mid + 1
    else
      Right := Mid - 1;
  end;
  Result := Left;
end;

// ======================================
// BINARY INSERTION SORT С MOVE
// ======================================

procedure BinaryInsertionSort(var Arr: TIntArray);
var
  i, pos, Key, shift, n: Integer;
begin
  n := Length(Arr);
  for i := 1 to n - 1 do
  begin
    Key := Arr[i];
    pos := BinSearchInt(Arr, 0, i - 1, Key);
    if i <> pos then
    begin
      shift := i - pos;
      Move(Arr[pos], Arr[pos + 1], shift * SizeOf(Integer));
      Arr[pos] := Key;
    end;
  end;
end;

procedure BinaryInsertionSort(var Arr: TRealArray);
var
  i, pos, shift, n: Integer;
  Key: Real;
begin
  n := Length(Arr);
  for i := 1 to n - 1 do
