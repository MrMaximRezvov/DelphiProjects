// ======================================
// SELECTION SORT
// ======================================

procedure SelectionSort(var Arr: TIntArray);
var
  i, j, minIdx, temp, n: Integer;
begin
  n := Length(Arr);
  for i := 0 to n - 2 do
  begin
    minIdx := i;
    for j := i + 1 to n - 1 do
      if Arr[j] < Arr[minIdx] then
        minIdx := j;
    if minIdx <> i then
    begin
      temp := Arr[i];
      Arr[i] := Arr[minIdx];
      Arr[minIdx] := temp;
    end;
  end;
end;

