procedure BinaryInsertionSort(var Arr: TRealArray); overload;
procedure BinaryInsertionSort(var Arr: TCharArray); overload;

implementation

// ======================================
// BUBBLE SORT
// ======================================

procedure BubbleSort(var Arr: TIntArray);
var
  i, j, temp, n: Integer;
begin
  n := Length(Arr);
  for i := 0 to n - 2 do
    for j := 0 to n - 2 - i do
      if Arr[j] > Arr[j + 1] then
      begin
        temp := Arr[j];
        Arr[j] := Arr[j + 1];
        Arr[j + 1] := temp;
      end;
end;

procedure BubbleSort(var Arr: TRealArray);
var
  i, j, n: Integer;
  temp: Real;
begin
  n := Length(Arr);
  for i := 0 to n - 2 do
    for j := 0 to n - 2 - i do
      if Arr[j] > Arr[j + 1] then
      begin
        temp := Arr[j];
        Arr[j] := Arr[j + 1];
        Arr[j + 1] := temp;
      end;
end;

procedure BubbleSort(var Arr: TCharArray);
var
  i, j, n: Integer;
  temp: AnsiChar;
begin
  n := Length(Arr);
  for i := 0 to n - 2 do
    for j := 0 to n - 2 - i do
      if Arr[j] > Arr[j + 1] then
