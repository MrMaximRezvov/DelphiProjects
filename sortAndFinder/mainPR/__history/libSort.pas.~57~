      Arr[pos] := Key;
    end;
  end;
end;

procedure BinaryInsertionSort(var Arr: TCharArray);
var
  i, pos, shift, n: Integer;
  Key: AnsiChar;
begin
  n := Length(Arr);
  for i := 1 to n - 1 do
  begin
    Key := Arr[i];
    pos := BinSearchChar(Arr, 0, i - 1, Key);
    if i <> pos then
    begin
      shift := i - pos;
      Move(Arr[pos], Arr[pos + 1], shift * SizeOf(AnsiChar));
      Arr[pos] := Key;
    end;
  end;
end;

