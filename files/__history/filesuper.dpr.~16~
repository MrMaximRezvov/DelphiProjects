program filesuper;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils, windows;

type
  mytype = type ansistring(1251);
  ts = array of mytype;
  tchar = #192 .. #255;

var
  aw: ts; // array of words
  s, s1: mytype;
  i: int32;
  fin, fout: textfile;
  f_name: ansistring;
  char: ansichar;

procedure findwords(s, s1: mytype; aw: ts);
var
  i, j: int32;
begin
  for i := 1 to high(s) do
    if s[i] in [low(tchar) .. high(tchar)] then
      s1 := mytype(s1) + mytype(s[i])
    else if s1 <> '' then
    begin
      aw := aw + [mytype(s1)];
      s1 := '';
    end;
  // 'хочу все знать'
  // не нужен, если добавляем в конце ' ';
  if s1 <> '' then
    aw := aw + [s1];
  writeln('Всего слов: ', length(aw));
  for i := 0 to High(aw) do
    writeln('<', mytype(aw[i]), '>');
  writeln(#10#10);
  aw := nil;
end;

begin

  setconsoleoutputCP(1251);
  setconsolecp(1251);
  repeat
    try
      writeln('Введите имя файла чтения');
      readln(f_name);
      f_name := ansitoutf8(f_name);
      assignfile(fin, f_name + '.txt');
      writeln('check');
      while not Eof(fin) do
      begin
        write('check2');
        while not Eoln(fin) do
        begin
          read(fin, char);
          s := s + mytype(char);
        end;
//        writeln('check');
//        read(fin, s);
        s := mytype(s);
        // s:=utf8toansi(s);
        s1 := '';
        findwords(s, s1, aw);
        s := '';
      end;
      //writeln('Введите предложение на русском языке : ');
      // readln(s);
      // s := mytype(s);
      // // s:=utf8toansi(s);
      // s1 := '';
      // findwords(s, s1, aw);
      // closefile(fin);
      readln;
      // s:=s+' ';
    except
      on E: Exception do
        writeln(E.ClassName, ': ', E.Message);
    end;
  until false;

end.
