program Project2;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils;

type
  PSt = ^TSt; // Указатель на тип TSt

  TSt = record
    first_name: string[20]; // Номер участника
    next: PSt; // Следующий элемент списка
  end;

var
  head: PSt = nil; // Начало (голова) списка
  Last: PSt = nil; // Последний элемент списка
  curr: PSt;
  ans: char;
  count: integer = 0; // Количество элементов списка
  num, i, n_p: integer;
  reccom: THeapStatus; // Для сервисной информации

// Создание нового элемента
function new_rec: PSt;
var
  curr: PSt;
begin
  new(curr);
  write('Номер участника : ');
  readln(curr^.first_name);
  curr^.next := nil;
  result := curr;
end;

// Добавление элемента в конец списка
procedure add(var head: PSt; var Last: PSt; var count: integer);
var
  curr: PSt;
begin
  curr := new_rec;
  if head = nil then
    head := curr
  else
    Last^.next := curr;
  Last := curr;
  inc(count);
end;

// Просмотр списка
procedure view_list(curr: PSt);
var
  i: integer;
begin
  i := 0;
  writeln('Список участников:');
  while curr <> nil do
  begin
    inc(i);
    writeln(i:5, '. Участник ', curr^.first_name);
    curr := curr^.next;
  end;
  writeln('Всего участников: ', i);
end;

// Зацикливание списка
procedure make_circular(var head: PSt; var Last: PSt);
begin
  if Last <> nil then
    Last^.next := head; // Замыкаем список
  writeln('Список зациклен.');
end;

procedure swop(var head: PSt; index1, index2: integer);
var
  prev1, curr1, prev2, curr2, temp: PSt;
  i: integer;
begin
  // Проверка на корректность индексов
  if (index1 < 1) or (index2 < 1) or (index1 = index2) then
  begin
    writeln('Ошибка: Некорректные индексы.');
    Exit;
  end;

  // Находим первый элемент и его предыдущий
  prev1 := nil;
  curr1 := head;
  for i := 1 to index1 - 1 do
  begin
    if curr1 = nil then
    begin
      writeln('Ошибка: Индекс ', index1, ' выходит за пределы списка.');
      Exit;
    end;
    prev1 := curr1;
    curr1 := curr1^.next;
  end;

  // Находим второй элемент и его предыдущий
  prev2 := nil;
  curr2 := head;
  for i := 1 to index2 - 1 do
  begin
    if curr2 = nil then
    begin
      writeln('Ошибка: Индекс ', index2, ' выходит за пределы списка.');
      Exit;
    end;
    prev2 := curr2;
    curr2 := curr2^.next;
  end;

  // Если один из элементов не найден
  if (curr1 = nil) or (curr2 = nil) then
  begin
    writeln('Ошибка: Один из элементов не найден.');
    Exit;
  end;

  // Обмен элементами
  if prev1 = nil then
    head := curr2
  else
    prev1^.next := curr2;

  if prev2 = nil then
    head := curr1
  else
    prev2^.next := curr1;

  temp := curr1^.next;
  curr1^.next := curr2^.next;
  curr2^.next := temp;

  writeln('Элементы с индексами ', index1, ' и ', index2, ' успешно обменяны.');
end;

procedure clear_list(var head: PSt; var Last: PSt; var count: integer);
var
  curr, next: PSt;
begin
  curr := head;

  while curr <> nil do
  begin
    Dispose(curr);
    curr := curr^.next;
  end;
  head := nil;
  Last := nil;
  count := 0;

  writeln('Список успешно очищен.');
end;

procedure delete_by_index(var head: PSt; var Last: PSt; var count: integer;
  index: integer);
var
  curr, prev: PSt;
  i: integer;
begin
  if (head = nil) or (index < 1) or (index > count) then
  begin
    writeln('Ошибка: Некорректный номер элемента или список пуст.');
    Exit;
  end;

  curr := head;
  prev := nil;

  for i := 1 to index - 1 do
  begin
    prev := curr;
    curr := curr^.next;
  end;

  if prev = nil then
    head := curr^.next
  else
    prev^.next := curr^.next;

  if curr^.next = nil then
    Last := prev;

  Dispose(curr);
  Dec(count);

  writeln('Элемент с номером ', index, ' успешно удален.');
end;

function count_elements(head: PSt): integer;
var
  curr: PSt;
  count: integer;
begin
  count := 0;
  curr := head;

  while curr <> nil do
  begin
    Inc(count);
    curr := curr^.next;
  end;

  Result := count;
end;

procedure insert_by_index(var head: PSt; var Last: PSt; var count: integer;
  index: integer);
var
  curr, prev, newElem: PSt;
  i: integer;
begin
  if (index < 1) or (index > count + 1) then
  begin
    writeln('Ошибка: Некорректный индекс для вставки.');
    Exit;
  end;

  newElem := new_rec;

  if index = 1 then
  begin
    newElem^.next := head;
    head := newElem;
    if Last = nil then
      Last := newElem;
  end
  else
  begin
    prev := nil;
    curr := head;
    for i := 1 to index - 1 do
    begin
      prev := curr;
      curr := curr^.next;
    end;

    prev^.next := newElem;
    newElem^.next := curr;

    if curr = nil then
      Last := newElem;
  end;

  Inc(count);
  writeln('Элемент успешно вставлен на позицию ', index);
end;

//
function service: string;
begin
  reccom := GetHeapStatus;
  with reccom do
    service := 'Общий размер кучи = ' + TotalAddrSpace.toString + ' Занято = ' +
      TotalAllocated.toString;
end;

procedure unlink_list(var head: PSt; var Last: PSt);
begin
  if (head = nil) or (Last = nil) then
  begin
    writeln('Список пуст или не зациклен.');
    Exit;
  end;
  if Last^.next = head then
  begin
    Last^.next := nil;
    writeln('Список успешно разомкнут.');
  end
  else
    writeln('Список уже линейный.');
end;
// Поиск счастливчиков
procedure find_winners(head: PSt; M, K: integer);
var
  curr, prev: PSt;
  i: integer;
begin
  if head = nil then
  begin
    writeln('Список пуст.');
    Exit;
  end;

  // Зацикливаем список, если он еще не зациклен
  if Last^.next <> head then
    make_circular(head, Last);

  curr := head;
  prev := nil;

  // Пока в списке больше K участников
  while count > K do
  begin
    // Проходим M шагов
    for i := 1 to M - 1 do
    begin
      prev := curr;
      curr := curr^.next;
    end;

    // Удаляем текущего участника
    writeln('Участник ', curr^.first_name, ' выбывает.');
    if curr = head then
      head := curr^.next
    else
      prev^.next := curr^.next;

    Dispose(curr);
    Dec(count);

    // Переходим к следующему участнику
    curr := prev^.next;
  end;

  // Выводим оставшихся участников
  writeln('Счастливчики:');
  curr := head;
  for i := 1 to K do
  begin
    writeln('Участник ', curr^.first_name);
    curr := curr^.next;
  end;
end;

// Основная программа
begin
  repeat
    try
      writeln;
      writeln('---Меню--------');
      writeln('1. Добавить участника');
      writeln('2. Сервис');
      writeln('3. Просмотр списка');
      writeln('4. Число участников в списке');
      writeln('5. Перейти к участнику');
      writeln('6. Удалить участника по номеру');
      writeln('7. Вставить участника по номеру');
      writeln('8. Очистить список');
      writeln('9. Зациклить список');
      writeln('10. Создать список из N участников');
      writeln('11. Найти счастливчиков');
      writeln('12. Разомкнуть список.');
      writeln('-----------------');
      writeln('Ваш выбор : ');
      readln(n_p);
      writeln;
      case n_p of
        1:
          add(head, Last, count);
        2:
          writeln(service);
        3:
          view_list(head);
        4:
          writeln('Количество участников: ', count);
        6:
          begin
            writeln('Введите номер участника для удаления: ');
            readln(num);
            delete_by_index(head, Last, count, num); // Удаляем участника по номеру
          end;
        7:
          begin
            writeln('Введите индекс для вставки: ');
            readln(num);
            insert_by_index(head, Last, count, num); // Вставляем участника по индексу
          end;
        8:
          clear_list(head, Last, count); // Очищаем список
        9:
          make_circular(head, Last); // Зацикливаем список
        10:
          begin
            writeln('Введите количество участников: ');
            readln(num);
            for i := 1 to num do
              add(head, Last, count); // Создаем список из N участников
          end;
        11:
          begin
            writeln('Введите M (шаг считалки): ');
            readln(num);
            writeln('Введите K (количество счастливчиков): ');
            readln(i);
            find_winners(head, num, i); // Находим счастливчиков
          end;
        12:
          unlink_list(head, Last); // Размыкаем список
      end;
    except
      on E: Exception do
        writeln(E.ClassName, ': ', E.Message);
    end;
  until false;
end.
