program pr3;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  SysUtils;

var
  n, i, j: Integer;
  data: array of array of Integer;
  first, second: Integer;
  fin: textfile;
  f_name: string;

begin
  writeln('Введите имя файла чтения');
  Readln(f_name);
  assignfile(fin, f_name + '.txt');
  reset(fin);
  Readln(fin, n);
  SetLength(data, n, 2);

  for i := 0 to n - 1 do
  begin
    Readln(fin, first, second);
    data[i][0] := first;
    data[i][1] := second;
  end;

 for i := 0 to n - 1 do
  begin
    for j := i + 1 to n - 1 do
    begin
      if data[i][0] = data[j][0] then
      begin
        if data[i][1] >= data[j][1] then
        begin
          data[j][0] := 0;
          data[j][1] := 0;
          Break;
        end;
        data[i][0] := 0;
        data[i][1] := 0;
        Break;
      end;
    end;
  end;

  // Вывод результата
  writeln('Результат:');
  for i := 0 to n - 1 do
  begin
    if (data[i][0] <> 0) or (data[i][1] <> 0) then
      writeln(data[i][0], ' ', data[i][1]);
  end;

  Readln; // Удержание консоли

end.
