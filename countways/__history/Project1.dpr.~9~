function CountWays(x, y: int64): uint64;
var
  i: uint64;
  numerator, denominator: uint64;
begin
  numerator := 1;
  denominator := 1;

  for i := 0 to x - 2 do
    numerator := numerator * (y + i - 1);

  for i := 1 to y - 1 do
    denominator := denominator * i;

  Result := numerator div denominator;
end;

var
  x, y: uint64;

begin
  try
    repeat
      Write('Введите координату X: ');
      ReadLn(x);
      Write('Введите координату Y: ');
      ReadLn(y);

      if (x < 1) or (y < 1) then
      begin
        WriteLn('Координаты должны быть больше или равны 1.');
      end
      else
      begin
        WriteLn('Количество возможных путей от (1, 1) к (', x, ', ', y, '): ',
          CountWays(x, y));
      end;

      ReadLn;
    until false;
  except
    on E: Exception do
      WriteLn(E.ClassName, ': ', E.Message);
  end;

end.
