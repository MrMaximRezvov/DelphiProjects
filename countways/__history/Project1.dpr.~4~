program Project1;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  SysUtils;

function Factorial(n: Integer): int64;
var
  i: int64;
begin
  Result := 1;
  for i := 2 to n do
    Result := Result * i;
end;

function CountWays(x, y: int64): int64;
begin
  Result := Factorial(x + y - 2) div (Factorial(x - 1) * Factorial(y - 1));
end;

var
  x, y: int64;

begin
  repeat
    Write('Введите координату X: ');
    ReadLn(x);
    Write('Введите координату Y: ');
    ReadLn(y);

    if (x < 1) or (y < 1) then
    begin
      WriteLn('Координаты должны быть больше или равны 1.');
    end;

    WriteLn('Количество возможных путей от (1, 1) к (', x, ', ', y, '): ',
      CountWays(x, y));
    ReadLn;
  until false;

end.
