program priceways;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.Sysutils;

// windows;

type
  myt = uint64;
  tm = array of myt;
  tmatr = array of myt;
  tematr = array of tmatr;

var
  ku, kr, m, n, k, kf, kuf, krf, rez, ko, vozv, dv, sum, last: myt;
  i, j: cardinal; // uint32
  s, s1: string;
  mu: tm;
  elem, eleml: tmatr;
  matr: tematr;

begin
  repeat
    try
      write('Input n,m(колонки, строки) = ');
      readln(n, m);
      setlength(matr, m);
      setlength(elem, n);
      for i := 0 to m-1 do
      begin
        for j := 0 to n-1 do
        begin
          elem[j] := random(100);
        end;
        matr[i] := elem;
      end;
      for i := 0 to m-1 do
      begin
        elem := matr[i];
        for j := 0 to n-1 do
        begin
          write(elem[j]:5);
        end;
        writeln;
      end;
      writeln('price point');
      elem := matr[0];
      write(elem[0]:4);
      for i := 1 to n-1 do
      begin
        inc(elem[i], elem[i-1]);
        write(elem[i]:4);
      end;
      writeln;
      elem := matr[0];
      last := elem[0];
      for i := 1 to m-1 do
      begin
        elem := matr[i];
        inc(elem[0], last);
        last := elem[0];
      end;
      for i := 1 to m-1 do
      begin
        eleml := matr[i-1];
        elem := matr[i];
        for j := 1 to n-1 do
        begin
          if elem[j-1] < eleml[j] then inc(elem[j], elem[j-1]) else inc(elem[j], eleml[j]);
        end;
      end;
      for i := 0 to m-1 do
      begin
        elem := matr[i];
        for j := 0 to n-1 do
        begin
          write(elem[j]:10);
        end;
        writeln;
      end;
      //////
      readln;

    except
      on E: Exception do
        writeln(E.ClassName, ': ', E.Message, ' ', s1);
    end;
    //
  until false;

  //
end.
