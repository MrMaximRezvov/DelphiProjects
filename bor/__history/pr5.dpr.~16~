procedure travelup_n(cur: PEl; s:twin1251;var m:uint32);//s='';
//cur=root
var
  a: tchar;
  cur2: PEl;
begin

if cur=nil then exit;
  a := low(tchar);
  for cur2 in cur^.Link do
  begin
    if cur2 <> nil then
    begin
      if cur^.f then
        begin
        writeln(s + a,' ':(25-length(s+a)));
        inc(m);
        end;
      travelup_n(cur2,s+a,m);
    end;
    a := succ(a);
  end;



end;

procedure travelup(cur: PEl; s: twin1251);
var
  a: tchar;
  cur2: PEl;
begin
if cur=nil then exit;

  a := low(tchar);
  for cur2 in cur^.Link do
  begin
    if cur2 <> nil then
    begin
      if cur2^.f then
        writeln(twin1251(twin1251(s) + twin1251(a)):25);
      travelup(cur2,twin1251(twin1251(s)+twin1251(a)));
    end;
    a := tchar(succ(a));
  end;
end;

// Остальные функции остаются без изменений (SearchWord, LoadFromFile...)
function SearchWord(s: twin1251): Boolean;
var
  curr: PEl;
  i: Integer;
  c: tChar;
begin
  curr := root;
  for i := 1 to Length(s) do
  begin
    c := s[i];
    if not (c in [Low(tchar)..High(tchar)]) or (curr^.Link[c] = nil) then
      Exit(False);
    curr := curr^.Link[c];
  end;
  Result := curr^.f;
end;

// Загрузка из файла
procedure LoadFromFile(fname: twin1251);
var
  f: TextFile;
  s: twin1251;
  StartTime: DWORD;
begin
  StartTime := GetTickCount;
  AssignFile(f, fname);
  Reset(f);
  while not Eof(f) do
  begin
    Readln(f, s);
    InsertWord(s);
  end;
  CloseFile(f);
  Writeln('Загружено слов: ', uk);
  Writeln('Время загрузки: ', GetTickCount - StartTime, ' мс');
end;

// Обновленное меню
procedure PrintMenu;
begin
  Writeln('*** Меню ***');
  Writeln('1. Показать меню');
  Writeln('2. Вставить слово');
  Writeln('3. Найти слово');
  Writeln('4. Удалить слово');
  Writeln('5. Вывести все слова');
  Writeln('6. Загрузить из файла');
  Writeln('7. Выход');
end;

// Основная программа
var
  cmd: Integer;
  sInput: twin1251;
begin
  SetConsoleCP(1251);
  SetConsoleOutputCP(1251);

  InitBor;
  PrintMenu;
  try
  while not quitFlag do
  begin
    Write('>> ');
    Readln(sInput);

    if TryStrToInt(sInput, cmd) then
    begin
      case cmd of
        1: PrintMenu;
        2: begin
          while true do
          begin
            Write('Введите слово(для выхода введите exit): ');
            Readln(sInput);
            if sInput = 'exit' then
              break;
            InsertWord(sInput);
          end;
           end;
        3: begin
            Write('Введите слово для поиска: ');
            Readln(sInput);
            if SearchWord(sInput) then
              Writeln('Слово найдено')
            else
              Writeln('Слово не найдено');
           end;
        4: begin
            Write('Введите слово для удаления: ');
            Readln(sInput);
            DeleteWord(sInput);
           end;
        5: travelup(root, '');
        6: begin
            Write('Введите имя файла: ');
            Readln(sInput);
            LoadFromFile(sInput);
           end;
        7: quitFlag := True;
        else Writeln('Неверная команда');
      end;
    end
    else
    begin
      Writeln('Введите числовую команду');
    end;
  end;
  except
     On E:Exception Do
      writeln(E.ClassName, E.Message);
  end;

  Writeln('Работа завершена');
end.
