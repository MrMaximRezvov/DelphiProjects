procedure travelup_n(cur: PEl; s: twin1251; var m: uint32); // s='';
// cur=root
var
  a: tchar;
  cur2: PEl;
begin

  if cur = nil then
    Exit;
  a := low(tchar);
  for cur2 in cur^.Link do
  begin
    if cur2 <> nil then
    begin
      if cur^.f then
      begin
        Writeln(s + a, ' ':(25 - Length(s + a)));
        Inc(m);
      end;
      travelup_n(cur2, s + a, m);
    end;
    a := succ(a);
  end;

end;

procedure travelup(cur: PEl; s: twin1251);
var
  a: tchar;
  cur2: PEl;
begin
  if cur = nil then
    Exit;

  a := low(tchar);
  for cur2 in cur^.Link do
  begin
    if cur2 <> nil then
    begin
      if cur2^.f then
        Writeln(twin1251(twin1251(s) + twin1251(a)):25);
      travelup(cur2, twin1251(twin1251(s) + twin1251(a)));
    end;
    if ord(a) < 255 then
      a := tchar(succ(a));
  end;
end;

// Остальные функции остаются без изменений (SearchWord, LoadFromFile...)
function SearchWord(s: twin1251): Boolean;
var
  curr: PEl;
  i: Integer;
  c: tchar;
begin
  curr := root;
  for i := 1 to Length(s) do
  begin
    c := s[i];
    if not(c in [Low(tchar) .. High(tchar)]) or (curr^.Link[c] = nil) then
      Exit(False);
    curr := curr^.Link[c];
  end;
  Result := curr^.f;
end;

// Загрузка из файла
procedure LoadFromFile(fname: twin1251);
var
  f: TextFile;
  StartTime: DWORD;
  aw: array of twin1251; // array of words
  s, s1: twin1251;
  i: Int32;
begin
  try
    StartTime := GetTickCount;
    AssignFile(f, fname);
    Reset(f);
    while not Eof(f) do
    begin
      Readln(f, s);
      s := twin1251(s);
      //s := twin1251(utf8toansi(s));
      //writeln('s= ', s);
      s1 := '';
      // s:=s+' ';
      for i := 1 to high(s) do
        if s[i] in [low(tchar) .. high(tchar)] then
          s1 := twin1251(s1) + twin1251(s[i])
        else if s1 <> '' then
        begin
          aw := aw + [twin1251(s1)];
          s1 := '';
        end;
      // 'хочу все знать'
      // не нужен, если добавляем в конце ' ';
      if s1 <> '' then
        aw := aw + [s1];
      //Writeln('Всего слов: ', Length(aw));
      for i := 0 to High(aw) do
      begin
        //Writeln('<', twin1251(aw[i]), '>');
        InsertWord(twin1251(aw[i]));
      end;
      Writeln(#10#10);
      aw := nil;
    end;
    CloseFile(f);
    Writeln('Загружено слов: ', uk);
    Writeln('Время загрузки: ', GetTickCount - StartTime, ' мс');
  except
    On E: Exception Do
      Writeln(E.ClassName, E.Message);
  end;
end;

// Обновленное меню
procedure PrintMenu;
begin
  Writeln('*** Меню ***');
  Writeln('1. Показать меню');
  Writeln('2. Вставить слово');
  Writeln('3. Найти слово');
  Writeln('4. Удалить слово');
  Writeln('5. Вывести все слова');
  Writeln('6. Загрузить из файла');
  Writeln('7. Выход');
end;

// Основная программа
var
  cmd: Integer;
  sInput, s: twin1251;
  cur: PEl;

begin
  SetConsoleCP(1251);
  SetConsoleOutputCP(1251);

  InitBor;
  PrintMenu;
  try
    while not quitFlag do
    begin
      Write('>> ');
      Readln(sInput);

      if TryStrToInt(sInput, cmd) then
      begin
        case cmd of
          1:
            PrintMenu;
          2:
            begin
              while True do
              begin
                Write('Введите слово(для выхода введите exit): ');
                Readln(sInput);
                if sInput = 'exit' then
                  break;
                InsertWord(sInput);
              end;
            end;
          3:
            begin
              Write('Введите слово для поиска: ');
              Readln(sInput);
              if SearchWord(sInput) then
                Writeln('Слово найдено')
              else
                Writeln('Слово не найдено');
            end;
          4:
            begin
              Write('Введите слово для удаления: ');
              Readln(sInput);
              DeleteWord(sInput);
            end;
          5:
            begin
              Writeln('Использовано элементов - ', uk, #10);
              cur := root;
              s := '';
              travelup(root, '');
            end;
          6:
            begin
              Write('Введите имя файла: ');
              Readln(sInput);
              LoadFromFile(twin1251(sInput + '.txt'));
            end;
          7:
            quitFlag := True;
        else
          Writeln('Неверная команда');
        end;
      end
      else
      begin
        Writeln('Введите числовую команду');
      end;
    end;
  except
    On E: Exception Do
      Writeln(E.ClassName, E.Message);
  end;

  Writeln('Работа завершена');

end.
