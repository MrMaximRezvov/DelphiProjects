program pr6;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  SysUtils,
  Windows;

type
  twin1251 = type AnsiString(1251);
  tchar = #192 .. #255;
  PEl = ^TEl;

  TEl = record
    count: UInt16;
    f: Boolean;
    cn: uint32;
    Link: array [tchar] of PEl;
  end;

const
  maxEl = 10000;

var
  bor: array [0 .. maxEl] of TEl;
  uk: Int32 = 0;
  root: PEl = nil;
  quitFlag: Boolean = False;
  m: uint32;

  // Инициализация узла
procedure InitNode(var node: TEl);
var
  c: tchar;
begin
  node.f := False;
  node.count := 0;
  for c := Low(tchar) to High(tchar) do
    node.Link[c] := nil;
end;

// Инициализация структуры
procedure InitBor;
var
  i: Integer;
begin
  for i := 0 to maxEl do
    InitNode(bor[i]);
  uk := 0;
  root := @bor[0];
end;

// Вставка слова
procedure InsertWord(s: twin1251);
var
  curr: PEl;
  i: Integer;
  c: tchar;
begin
  curr := root;
  for i := 1 to Length(s) do
  begin
    c := s[i];
    if not(c in [Low(tchar) .. High(tchar)]) then
    begin
      Writeln('Ошибка: Недопустимый символ "', c, '"');
      Exit;
    end;

    if curr^.Link[c] = nil then
    begin
      Inc(uk);
      if uk > maxEl then
      begin
        Writeln('Ошибка: Превышен лимит элементов бора');
        Exit;
      end;
      curr^.Link[c] := @bor[uk];
      InitNode(bor[uk]);
    end;
    curr := curr^.Link[c];
    Inc(curr^.count);
  end;
  curr^.f := True;
end;

// Удаление слова
procedure DeleteWord(s: twin1251);
var
  curr: PEl;
  path: array of PEl;
  i, idx: Integer;
  c: tchar;
begin
  SetLength(path, Length(s));
  curr := root;
  idx := 0;

  // Построение пути
  for i := 1 to Length(s) do
  begin
    c := s[i];
    if not(c in [Low(tchar) .. High(tchar)]) or (curr^.Link[c] = nil) then
    begin
      Writeln('Слово не найдено');
      Exit;
    end;
    path[idx] := curr;
    Inc(idx);
    curr := curr^.Link[c];
  end;

  if not curr^.f then
  begin
    Writeln('Слово не найдено');
    Exit;
  end;

  // Помечаем как удаленное
  curr^.f := False;
  Dec(curr^.count);

  // Удаление ненужных узлов
  for i := Length(s) downto 1 do
  begin
    Dec(idx);
    c := s[i];
    curr := path[idx]^.Link[c];

    if curr^.count = 0 then
    begin
      path[idx]^.Link[c] := nil;
      InitNode(bor[uk]);
      Dec(uk);
    end;
  end;
  Writeln('Слово успешно удалено');
end;

// Рекурсивный вывод слов
procedure PrintWords(node: PEl; prefix: twin1251);
var
  c: tchar;
begin
  if node^.f then
    Writeln(prefix);

  for c := Low(tchar) to High(tchar) do
  begin
    if node^.Link[c] <> nil then
      PrintWords(node^.Link[c], prefix + c);
  end;
end;

// Вывод всех слов
procedure PrintAllWords;
begin
  if root = nil then
  begin
    Writeln('Бор пуст');
    Exit;
  end;
  Writeln('Список всех слов:');
  PrintWords(root, '');
end;
