program Project1;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils;

type myt = int32;

function CountWays(n: myt): myt;
begin
  if n < 0 then
    Exit(0);
  if n = 0 then
    Exit(1);
  if n = 1 then
    Exit(1);
  if n = 2 then
    Exit(1);
  if n = 3 then
    Exit(2);

  Result := CountWays(n - 1) + CountWays(n - 3);
end;

var
  stairs: myt;

begin
  repeat
    Write('Введите количество ступенек: ');
    ReadLn(stairs);

    WriteLn('Количество возможных вариантов спусков: ', CountWays(stairs));
    ReadLn;
  until false;

end.
