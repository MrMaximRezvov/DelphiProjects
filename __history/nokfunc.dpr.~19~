program nokfunc;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils, windows;

var
  a, b, c, i, r, NOD, NOK: int32;

begin
  setconsoleoutputCP(1251);
  repeat
    writeln('Введите НОД и НОК скольки чисел хотите узнать:');
    readln(r);
    for i := 1 to r do
    begin
      a := a + b;
      writeln('Введите одно следующее целое значение: ');
      readln(b);


      while b <> 0 do
      begin
        c := b;
        b := a mod b;
        a := c;
      end;
      NOK:=  a*b div (a+b);
      NOD:= a + b;
      writeln('NOD=', a+b, ' NOK=', NOK, ' Кол-во чисел=', i);
      {
        writeln('Введите два целых ненулевых значения: ');
        readln(a);
        readln(b);
        if (a = 0) and (b = 0) then
        begin
        writeln('Не должны равняться 0');
        writeln('#####################################');
        continue;
        end;
        while b <> 0 do
        begin
        c := b;
        b := a mod b;
        a := c;
        end;
        writeln('NOD=', a + b);
        end;
        writeln('#####################################') }
    end;
  until false;

end.
