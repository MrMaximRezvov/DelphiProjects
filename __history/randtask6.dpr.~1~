program randtask6;

{$APPTYPE CONSOLE}

{$R *.res}

uses
  System.SysUtils;

var c: ansichar;
i, schet: int32;


begin
schet:= 0;
randseed:= 3;
for i := 1 to 1200 do
begin
c:= ansichar(random(ord('я')-ord('а') + 1) + ord('а'));
write(c);
//if ord(c) = 76 then inc(schet);
if c = 'V' then inc(schet);

end;
writeln(#10, 'schet= ', schet);
readln;
end.
