program bool1;

{$APPTYPE CONSOLE}

{$R *.res}

uses
  System.SysUtils;

var x, y, b1, b2, b3, b4, b5: boolean;

begin
for x := false to true do
  for y := false to true do
    begin
      b1:= not y;
      b2:= x or y;
      b3:= x and y;
      b4:= x xor y;
      b5:= not x;
      writeln(ord(x):2, ord(y):2, b1:2, b5:2, b2:2, b3:2, b4:2);
    end;
readln;
end.
