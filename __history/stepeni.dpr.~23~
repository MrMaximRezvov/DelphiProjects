program stepeni;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils, windows;

var
  rez,n, a, n1, c: int64;
  b, b1, b2: boolean;

begin
  setconsoleoutputCP(1251);
  repeat
    rez := 1;
    writeln('Введите значение a(основание степени), n(степень)');
    readln(a, n);
    //c:= 0;

    //if a>0 then b1:= true;
    if n>0 then b:= true;
      n:= abs(n);
      while n > 0 do
      begin
        if odd(n) then
          rez := rez * a;
        a := a * a;
        n := n shr 1;
      end;
      //b2:= odd(n);
      //if b1 <> true then if b2 = false then

      if b = True then  writeln('Результат= ', rez) else  writeln('Результат= 1/', rez)
  until false;
end.
