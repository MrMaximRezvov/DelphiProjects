program sdacha3;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils;

const
  inf = 50000;
  km = 4;

var
  n, n1, i: uint16;
  arm: array [1 .. km] of uint16 = (
    2,
    3,
    5,
    10
  );
  fm: array of uint16;

begin
  repeat
    try
      writeln(#10, 'Динамическое программирование');
      /// //////////////////////
      // write('Enter n = ');
      // readln(n);
      // setlength(fm, n + 1);
      // fm[0] := 0;
      // for i := 1 to n do
      // fm[i] := inf;
      // for i := 1 to km do
      // fm[arm[i]] := 1;
      // // n1-текущая сумма
      // for n1 := 2 to n do
      // begin
      // for i := 1 to km do
      // if (n1 >= arm[i]) and (fm[n1 - arm[i]] + 1 < fm[n1]) then
      // fm[n1] := fm[n1 - arm[i]] + 1;
      // end;
      // if fm[n] = inf then
      // writeln('no':4)
      // else
      // writeln('fm[n]=', fm[n]);
      // readln;
      // fm := nil;
      ///
      for i := 1 to 25 do
        write(i:3);
      writeln;
      write(' -  -  -  -  -  -  -  -  - ');
      for n := 10 to 25 do
      begin
        if not(n < 5) then
          setlength(fm, n + 1)
        else
        fm[0] := 0;
        for i := 1 to n do
          fm[i] := inf;
        for i := 1 to km do
          fm[arm[i]] := 1;
        // n1-текущая сумма
        for n1 := 2 to n do
        begin
          for i := 1 to km do
            if (n1 >= arm[i]) and (fm[n1 - arm[i]] + 1 < fm[n1]) then
              fm[n1] := fm[n1 - arm[i]] + 1;
        end;
        if fm[n] = inf then
          write('no':4)
        else
          write(fm[n]: 3);
        fm := nil;
      end;
      readln;
    except
      on E: Exception do
        writeln(E.ClassName, ': ', E.Message);
    end;
  until false;

end.
