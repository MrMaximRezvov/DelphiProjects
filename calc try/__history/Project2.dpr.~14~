program Project2;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils;

var
  a, b, c, nop, i: uint8;
  z: ansichar;
  op: boolean;
  s, s1: string;
  c1 : char;

begin
  repeat
    try
      { TODO -oUser -cConsole Main : Insert code here }
      writeln('Введите ваш пример через пробел.');
      nop := 1;
//      read(s);
//      a := StrToInt(s);
//      nop := 2;
//      readln(z, z, b);
      // readln(a, z, z, b);
      s1 := '';
      i := 1;
      while s[i] <> ' ' do
      begin
        s1 := s1 + s[i];
        inc(i);
        writeln(s1);
      end;
      nop := 1;
      a := StrToInt(s1);
      while s[i] <> ' ' do
      begin
        c1 := s[i];
        inc(i);
      end;
      s1 := '';
      while i <= length(s) do
      begin
        s1 := s1 + s[i];
        inc(i);
      end;
      nop := 2;
      b := StrToInt(s1);
      writeln(a, b);
      case z of
        '+':
          c := a + b;
        '-':
          c := a - b;
        '*':
          c := a * b;
        '/':
          c := a div b;
      else
        writeln('Знак операции неверный');
      end;
      writeln('Ответ: ', c);
    except
      // writeln('Какая-то ошибка.');
      // on E: Exception do
      // writeln(E.ClassName{, ': ', E.Message});
      on EDivByZero do
        writeln('Ошибка деления на ноль  в операции "', z, '"');
      on EintOverflow do
        writeln('Ошибка переполнения в операции "', z, '"');
      on EInOutError do
        writeln('Ошибка в операнде', nop);
      on ERangeError do
        writeln('Ошибка переполнения результата.');
      on cl1: Exception do
        writeln(cl1.ClassName);

    end;
    readln;
  until false;

end.
