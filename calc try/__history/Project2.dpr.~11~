program Project2;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils;

var
  a, b, c, nop: uint8;
  z: ansichar;
  op: boolean;
  s: string;

begin
  repeat
    try
      { TODO -oUser -cConsole Main : Insert code here }
      writeln('Введите ваш пример через пробел.');
      nop:=1;
      read(s);
      a := StrToInt(s);
      nop:=2;
      readln(z,z, b);
      //readln(a, z, z, b);

      case z of
        '+':
          c := a + b;
        '-':
          c := a - b;
        '*':
          c := a * b;
        '/':
          c := a div b;
      else
        writeln('Знак операции неверный');
      end;
      writeln('Ответ: ', c);
    except
      //writeln('Какая-то ошибка.');
//      on E: Exception do
//        writeln(E.ClassName{, ': ', E.Message});
      on EDivByZero do
              writeln('Ошибка деления на ноль  в операции "',z,'"');
      on EintOverflow do
              writeln('Ошибка переполнения в операции "',z,'"');
      on EInOutError do
              writeln('Ошибка в операнде', nop);
      on ERangeError do
            writeln('Ошибка переполнения результата.');
      on cl1:Exception do
        Writeln(cl1.ClassName);

    end;
    readln;
  until false;

end.
