program project3;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils,
  math;

type
  tarr = array of integer;
  tarr2 = array of tarr;

var
  i, j, n, w, tw, sum, k, tw2: integer;
  mw: tarr; // = { [9, 1, 3]; } [9, 1, 3]; //
  msol: tarr2;
  n1, tw1: integer;

  //
begin
  repeat

    sum := 0;
    write('Введите randseed: ');
    readln(randseed);
    setlength(mw, random(10) + 3);
    for i := 0 to length(mw) - 1 do
    begin
      mw[i] := random(10) + 1;
      inc(sum, mw[i]);
    end;
    n := length(mw);
    n1 := n;
    // readln(tw);
    // tw1 := tw;
    setlength(msol, n + 1, sum + 1);
    for w := 0 to sum do
      msol[0, w] := 0; // i=0 -number of good
    for i := 1 to n do
      msol[i, 0] := 0;
    // main
    for i := 1 to n do
      for w := 0 to sum do
      begin
        j := i - 1;
        msol[i, w] := msol[i - 1, w];
        if (w >= mw[j]) and ((msol[i - 1, w - mw[j]] + mw[j]) > msol[i, w]) then
          msol[i, w] := msol[i - 1, w - mw[j]] + mw[j];
      end;
    write('Набор слитков : ');
    for i := 0 to n - 1 do
      if i < n - 1 then
        write(mw[i]:3, ', ')
      else
        writeln(mw[i]:3);
    writeln('Сумма слитков : ', sum);
    writeln('Количество слитков : ', length(mw));
    //
    for w := 0 to sum do
      if w < sum then
        write(w:3)
      else
        writeln(w:3);
    writeln;
    for i := 0 to n do
      for w := 0 to sum do
        if w < sum then
          write(msol[i, w]:3)
        else
          writeln(msol[i, w]:3);

    // back
    write(#10, 'Введите возможности грузчика : ');
    readln(tw1);
    tw2:= tw1;
    write('Грузчик взял: ', msol[n, tw1]);
    write(#10, 'Cлитки:');
    while msol[n1, tw1] > 0 do
    begin
      if msol[n1, tw1] > msol[n1 - 1, tw1] then
      begin
        write(' ', mw[n1 - 1]:3, ';');
        dec(n1, 1);
        tw1 := tw1 - mw[n1];
      end
      else
        dec(n1, 1);
    end;
    writeln;
    write('Введите количество слитков: ');
    readln(k);
    write('Грузчик взял: ', msol[k, tw2]);
    writeln('Слитки: ');
    while msol[k, tw2] > 0 do
    begin
      if msol[k, tw2] > msol[k - 1, tw2] then
      begin
        write(' ', mw[k - 1]:3, ';');
        dec(k, 1);
        tw2 := tw2 - mw[k];
      end
      else
        dec(k, 1);
    end;
    writeln;
    // memory clear
    msol := nil;
  until false;

end.
