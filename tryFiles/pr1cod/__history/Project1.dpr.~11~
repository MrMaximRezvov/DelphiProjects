procedure readFileString(filename: string; stringNumber: int32);
var
  lineCount: int32;
  str: string;
  f1: textfile;
begin
  writeln(#10, 'result: ', #10);
  assignfile(f1, filename);
  reset(f1);
  lineCount := 0;
  while not Eof(f1) and (lineCount + 1 < stringNumber) do
  begin
    readln(f1);
    inc(lineCount);
  end;

  if Eof(f1) then
    writeln('Достигнут конец документа последний номер строки ', lineCount);

  readln(f1, str);
  writeln(str, #10);

  closefile(f1);
end;

