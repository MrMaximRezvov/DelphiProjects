procedure readMatrix(filename: string);
var
  f: textfile;
  n, m: uint32;
  i, j: int32;
  r: real;

begin
  arr := nil;
  setlength(arr, 0, 0);
  assignfile(f, filename);
  reset(f);
  readln(f, n, m);
  setlength(arr, n, m);
  for i := 0 to n - 1 do
  begin
    for j := 0 to m - 1 do
    begin
      read(f, r);
      arr[i][j] := r;
    end;
    readln(f);
  end;
  closefile(f);
end;

procedure calculations(op: string);
var
  s: string;
  statusOfExecution: int8;
  i: int8;
  op1, op2, code1, codeReal1, oper, code2, codeReal2: integer;
  op1real, op2real: real;
  minusStatus1, minusStatus2: boolean;

begin
  try

    statusOfExecution := 0; // Обнуление требуемых переменных.
    op := trim(op);
    s := '';
    i := 1;

    statusOfExecution := 1;
    // Распознование первого операнда //Доработать с отрицательными значениями.
    minusStatus1 := false;
    if op[i] = '-' then
    begin
      inc(i);
      minusStatus1 := true;
    end;
    while not(op[i] in [' ', '+', '-', '*', '/', 'd', 'm']) do
    begin
      s := s + op[i];
      inc(i);
      // writeln(i);
    end;
    val(s, op1, code1);
    val(s, op1real, codeReal1);
    // op1 := strToInt(s);
    if code1 <> 0 then
    begin
      writeln('Не удалось преобразовать первый операнд в целочисленный тип.');
    end;

    if codeReal1 <> 0 then
    begin
      raise Exception.Create('Ошибка преобразования первого операнда.');
    end;

    s := '';

    statusOfExecution := 2; // Распознование операции.
    while op[i] = ' ' do
    begin
      inc(i);
    end;

    case op[i] of
      '+':
        oper := 0;
      '-':
        oper := 1;
      '*':
        oper := 2;
      '/':
        oper := 3;
      'd':
        oper := 4;
      'm':
        oper := 5;
    else
      raise Exception.Create('Не удалось распознать операцию.');
    end;

    inc(i);

    s := '';

    statusOfExecution := 3; // Распознование второго операнда.

    while op[i] = ' ' do
    begin
      inc(i);
    end;

    minusStatus2 := false;
    if op[i] = '-' then
    begin
      inc(i);
      minusStatus2 := true;
    end;

    for i := i to length(op) do
    begin
      s := s + op[i];
    end;

    // writeln(s);
    val(s, op2, code2);
    val(s, op2real, codeReal2);
    // op1 := strToInt(s);
    if code2 <> 0 then
    begin
      writeln('Не удалось преобразовать второй операнд в целочисленный тип.');
    end;

    if codeReal2 <> 0 then
    begin
      raise Exception.Create('Ошибка преобразования второго операнда.');
    end;

    if(abs(op1) > 50) then
      raise Exception.Create('Большое значение операнда.');

    statusOfExecution := 4; // Подсчет значений.
    if minusStatus1 then
    begin
      op1 := -op1;
      op1real := -op1real;
    end;
    if minusStatus2 then
    begin
      op2 := -op2;
      op2real := -op2real;
    end;

    if (code1 = 0) and (code2 = 0) then
    begin
      writeln('Операнд 1 = ', op1);
      writeln('Операнд 2 номер с нуля (+-*/dm) = ', oper);
      writeln('Операнд 3 = ', op2);
      case oper of
        0:
          writeln(op1, ' + ', op2, ' = ', op1 + op2);
        1:
          writeln(op1, ' - ', op2, ' = ', op1 - op2);
        2:
          writeln(op1, ' * ', op2, ' = ', op1 * op2);
        3:
          writeln(op1, ' / ', op2, ' = ', (op1 / op2):0:2);
        4:
          writeln(op1, ' div ', op2, ' = ', op1 div op2);
        5:
          writeln(op1, ' mod ', op2, ' = ', op1 mod op2);
      end;
    end;

    if (codeReal1 = 0) and (codeReal2 = 0) then
    begin
      writeln('Операнд 1 = ', op1real:0:2);
      writeln('Операнд 2 номер с нуля (+-*/dm) = ', oper);
      writeln('Операнд 3 = ', op2real:0:2);
      case oper of
        0:
          writeln(op1real:0:2, ' + ', op2real:0:2, ' = ',
            (op1real + op2real):0:2);
        1:
          writeln(op1real:0:2, ' - ', op2real:0:2, ' = ',
            (op1real - op2real):0:2);
        2:
          writeln(op1real:0:2, ' * ', op2real:0:2, ' = ',
            (op1real * op2real):0:2);
        3:
          writeln(op1real:0:2, ' / ', op2real:0:2, ' = ',
            (op1real / op2real):0:2);
        4:
          writeln('Целочисленные операции не поддерживаются с нецелыми числами.');
        5:
          writeln('Целочисленные операции не поддерживаются с нецелыми числами.');
      end;
    end;

  except
    on E: Exception do
    begin
      case statusOfExecution of
        0:
          begin
            writeln('Ошибка инициализации.');
          end;
        1:
          begin
            writeln('Ошибка первого операнда.');
          end;
        2:
          begin
            writeln('Ошибка операции.');
          end;
        3:
          begin
            writeln('Ошибка второго операнда.');
          end;
        4:
          begin
            writeln('Ошибка вычислений.');
          end;
      end;
      //writeln(E.ClassName, ': ', E.Message);
    end;

  end;
end;

