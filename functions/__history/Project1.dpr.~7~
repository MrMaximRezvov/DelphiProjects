program Project1;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils;

type
  td1 = array of real;

function parabola(x: real; n: integer = 10; step: real = 1): td1;
var
  i: integer;
begin
  setlength(result, n);
  for i := 0 to n - 1 do
  begin
    result[i] := x * x;
    x := x + step;
  end;

end;

var
  arr: td1;
  i: integer;

begin
  try
    arr := parabola(0);
    for i := 0 to length(arr) - 1 do
      write(arr[i]:0:2, ' ');
    writeln;
    arr := parabola(0, 15, 2);
    for i := 0 to length(arr) - 1 do
      write(arr[i]:0:2, ' ');
    readln;
    { TODO -oUser -cConsole Main : Insert code here }
  except
    on E: Exception do
      Writeln(E.ClassName, ': ', E.Message);
  end;

end.
