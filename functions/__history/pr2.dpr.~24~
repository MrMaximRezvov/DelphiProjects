program pr2;

{$APPTYPE CONSOLE}
{$R *.res}

uses
  System.SysUtils, Math;

type
  td1 = array of real;
  tf1 = {reference to} function(x: real): real;  // Правильный тип для анонимных методов

// Функция-фабрика: создаёт параболу по коэффициентам a, b, c
function CreateParabola(a: real = 1; b: real = 0; c: real = 0): tf1;
begin
  Result := function(x: real): real
    begin
      Result := a * x * x + b * x + c;
    end;
end;

// Универсальная функция вычисления значений
function calcf(x: real; f: tf1; n: integer = 100; step: real = 0.01): td1;
var
  i: integer;
begin
  SetLength(Result, n);
  for i := 0 to n - 1 do
  begin
    Result[i] := f(x);
    x := x + step;
  end;
end;

// Вывод массива
procedure print(arr: td1);
var
  i: integer;
begin
  for i := 0 to High(arr) do
    Write(arr[i]:0:4, ' ');
  Writeln;
end;

var
  arr: td1;
  f: tf1;

begin
  try
    // Пример 1: парабола x^2 - 3x + 2
    f := CreateParabola(1, -3, 2);
    arr := calcf(0, f, 10, 0.5);
    Writeln('Парабола (x^2 - 3x + 2):');
    print(arr);

    // Пример 2: парабола 2x^2 - 1
    f := CreateParabola(2, 0, -1);
    arr := calcf(0, f, 10, 0.5);
    Writeln('Парабола (2x^2 - 1):');
    print(arr);

    // Пример 3: парабола по умолчанию (x^2)
    f := CreateParabola;
    arr := calcf(0, f, 5, 1);
    Writeln('Парабола по умолчанию (x^2):');
    print(arr);

    Writeln('Нажмите Enter для выхода...');
    Readln;
  except
    on E: Exception do
      Writeln(E.ClassName, ': ', E.Message);
  end;
end.
