uses
  System.SysUtils;

type td1 = array of real;

function parabola(x: real; n : integer = 10; step : real = 1): td1;
var
  i: integer;
begin
  setlength(result, n);
  for i := 0 to n-1 do
  begin
    result[i] := x*x;
    x:= x+step;
  end;

end;

