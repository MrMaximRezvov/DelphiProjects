// Вывод 1-го элемента списка
procedure gip_triangle(a,b: real; var c: real);
begin
  c:=sqrt(a*a+b*b);
end;

function sum_triangle(a,b: real; var s: real):real;
begin
  s:=(a*b)/2;
  result := s;
end;

