var
  i: int32;
  s, s1: string;
  p, p1: Pointer;
  ps: ^string;
  startTime, endTime, elapsedTime: DWORD;
  t1, t2, fr: int64;

procedure descr_str(p: Pointer);
var
  pint: ^int32;
  pw: ^uint16;
begin
  pint := p;
  dec(pint);
  writeln('---------');
  writeln('Adress ', uint32(p), #10, ' len ', pint^);
  dec(pint);
  writeln('Ref, ', pint^);
  dec(pint);
  pw := p;
  dec(pw);
  writeln('Size of char ', pw^);
  dec(pw);
  writeln('Code page ', pw^);
  writeln('-----------------');
//  dispose(pw);
//  pw := nil;
//  dispose(pint);
//  pint := nil;
end;

begin
  try
    s := 'привет';
    p := @s;
    ps := @s;
    writeln('!', ps^, '!');
    writeln('Adress i= ', uintptr(@i), ' Adress s= ', uintptr(p));
    writeln('Adress S in Heap = ', uintptr(p^), ' Adress s[1]= ',
      uintptr(@s[1]));
    writeln(ps^, ' ', uintptr(ps^));
    s1 := string.create('z', 25);
    writeln(s1, ' ', s1.length.ToString);
    writeln('Adress s1 = ', uintptr(@s1), ' adress s1 = ', uintptr(@s1[1]));
    s1 := 'Марко ';
    s := 'Канту ';
    startTime := GetTickCount;
    QueryPerformanceFrequency(fr);
    QueryPerformanceCounter(t1);
    for i := 1 to 2000000 do
    begin
      s1 := s1 + s;
    end;
    endTime := GetTickCount;
    elapsedTime := endTime - startTime;
    writeln('Length: ', s1.length.ToString);
    // Вычисление времени выполнения

    QueryPerformanceCounter(t2);
    writeln('Execution time(Tick): ', elapsedTime, ' ms');
    writeln('Time(Frequency): ', (t2 - t1) * 1000 / fr:0:3, 'ms');
    s := 'Всем привет!';
    p := @s[1];
    descr_str(p);

    readln;
  except
    on E: Exception do
      writeln(E.ClassName, ': ', E.Message);
  end;

